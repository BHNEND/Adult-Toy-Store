# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://ats_user:ats_default_change_me@localhost:5432/ats"
DB_USER=ats_user
DB_PASSWORD=ats_default_change_me
DB_NAME=ats
DB_PORT=5432

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com/api
